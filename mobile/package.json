{
  "name": "rice-mill-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "cross-env APP_ENV=development expo start",
    "start:prod": "cross-env APP_ENV=production expo start --no-dev",
    "android": "expo start --android",
    "android:dev": "cross-env APP_ENV=development expo start --android",
    "android:prod": "cross-env APP_ENV=production expo start --android --no-dev",
    "ios": "expo start --ios",
    "ios:dev": "cross-env APP_ENV=development expo start --ios",
    "ios:prod": "cross-env APP_ENV=production expo start --ios --no-dev",
    "web": "expo start --web",
    "build:android": "cross-env APP_ENV=production eas build --platform android",
    "build:ios": "cross-env APP_ENV=production eas build --platform ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "~2.0.0",
    "@react-native-community/slider": "^5.1.2",
    "@react-native-picker/picker": "2.8.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.5",
    "expo": "~52.0.0",
    "expo-camera": "~16.0.0",
    "expo-document-picker": "~12.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-location": "~18.0.0",
    "firebase": "^10.7.1",
    "i18next": "^25.8.13",
    "react": "18.3.1",
    "react-i18next": "^16.5.4",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-maps": "1.18.0",
    "react-native-paper": "^5.11.6",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "^15.15.4",
    "react-native-webview": "13.12.5",
    "react-redux": "^9.0.4",
    "redux-thunk": "^3.1.0",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "cross-env": "^7.0.3"
  },
  "private": true
}
