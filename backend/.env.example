# ==========================================
# Rice Mill Express Backend - .env Template
# ==========================================

# --- Core Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
# Local: mongodb://localhost:27017/ricemill
# Production (Atlas): mongodb+srv://<user>:<password>@cluster0.mongodb.net/ricemill
MONGO_URI=mongodb://localhost:27017/ricemill

# --- Redis & Socket.io ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Authentication Secrets ---
# MUST be long random strings in production
JWT_SECRET=your_jwt_secret_here_make_it_long_and_secure
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_make_it_long_and_secure
JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# --- Firebase Admin ---
FIREBASE_PROJECT_ID=rice-express-7eef4
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@rice-express-7eef4.iam.gserviceaccount.com
# Use literal \n for newlines in the private key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Key_Here\n-----END PRIVATE KEY-----\n"

# --- Cloudinary (Image Uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Razorpay (Payments) ---
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# --- Twilio (SMS/OTP) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# --- Email / SMTP (BullMQ Email Worker) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# --- Observability ---
SENTRY_DSN=your_sentry_dsn_here

# --- Admin Bypass ---
ADMIN_BYPASS_PASSWORD=optional_dev_bypass_password
